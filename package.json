{
  "name": "not-claude-code",
  "version": "0.1.2",
  "description": "A Claude Code clone implementation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ncc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test:network": "ts-node tests/network-test.ts",
    "test:memory": "ts-node tests/memory-system-test.ts",
    "test:auto-compact": "ts-node tests/auto-compact-test.ts",
    "test:git-tools": "ts-node tests/git-tools-test.ts",
    "test": "ts-node tests/file-tools-test.ts && ts-node tests/command-tools-test.ts && ts-node tests/search-tools-test.ts && ts-node tests/other-tools-test.ts && ts-node tests/storage-session-test.ts && ts-node tests/skill-test.ts && ts-node tests/agent-test.ts && ts-node tests/git-tools-test.ts"
  },
  "keywords": [
    "ai",
    "code-assistant",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "inquirer": "^8.2.6",
    "marked": "^5.0.0",
    "marked-terminal": "^5.2.0",
    "openai": "^4.28.0",
    "ora": "^5.4.1",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
